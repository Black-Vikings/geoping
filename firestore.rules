rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /configs/{configId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      // Allow create (resource doesn't exist yet)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid;
    }

    match /sessions/{configId} {
      // Familiar (owner) can read
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/configs/$(configId)).data.ownerUid
           == request.auth.uid;

      // Abuelo can write if writeToken matches
      allow write: if request.auth != null
        && request.resource.data.writeToken
           == get(/databases/$(database)/documents/configs/$(configId)).data.writeToken;
    }
  }
}
